{
  "rules": {
    "opportunities": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "scan_state": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "activation_codes": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "connected_clients": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
